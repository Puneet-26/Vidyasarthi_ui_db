# ============================================================================
# FLUTTER/DART PROJECT GITIGNORE
# Comprehensive gitignore for Flutter/Dart projects
# Last Updated: April 2026
# ============================================================================

# IMPORTANT: ALWAYS INCLUDE THESE
!.gitkeep
!.env.example

# ============================================================================
# ENVIRONMENT VARIABLES & SECRETS (NEVER COMMIT)
# ============================================================================
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
*.pem
*.key
*.jks
*.keystore
*.p8
*.p12
*.pfx
CREDENTIALS.txt
secrets/
.secrets/
private.key
app.key
config.json.private
credentials.json
service-account-key.json
private-key.json
certificates/
keys/
certs/

# ============================================================================
# FLUTTER & DART DEPENDENCIES
# ============================================================================
**/doc/api/
**/ios/Flutter/.last_build_id
**/ios/Flutter/Flutter.podspec
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.flutter/generated_plugins.cmake
.pub-cache/
.pub/
/build/
/coverage/
.metadata
pubspec.lock
packages/
.package_config.json

# ============================================================================
# IDE & EDITOR CONFIGURATION
# ============================================================================
# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/
.gradle/
.classpath
.factorypath
.project
.pydevproject
.settings/

# VS Code
.vscode/
.vscode/extensions/
.vscode/launch.json
.vscode/settings.json
.vscode/tasks.json

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim, Nano, Emacs
*.swp
*.swo
*~
.vim/
.emacs.d/
*_BACKUP_*
*_BASE_*
*_LOCAL_*
*_REMOTE_*

# ============================================================================
# FLUTTER GENERATED FILES
# ============================================================================
**/flutter/generated_plugin_registrant.cc
**/flutter/generated_plugin_registrant.h
**/flutter/generated_plugin_registrant.dart
**/flutter/generated_plugin_registrant.swift
**/flutter/generated_plugins.cmake
**/GeneratedPluginRegistrant.java
.dart_tool/flutter_gen/
**/GeneratedPluginRegistrant.swift
generated_plugin_registrant.m
generated_plugins.cmake

